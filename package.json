{
  "name": "reportary-email-service",
  "version": "1.0.0",
  "description": "Email queue service on Cloudflare Workers and D1",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply reportary-email-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply reportary-email-db --remote",
    "secrets:deploy": "node deploy-secrets.js"
  },
  "dependencies": {
    "worker-mailer": "^1.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240529.0",
    "typescript": "^5.4.5",
    "wrangler": "^3.57.1"
  }
}
